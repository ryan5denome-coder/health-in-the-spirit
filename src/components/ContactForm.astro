---
/**
 * ContactForm — auto-sending form via Web3Forms.
 *
 * Web3Forms is a free hosted form service (250 submissions/month free tier).
 * The "access key" is the destination email — whoever's email is registered to
 * the key receives form submissions.
 *
 * SETUP (one-time, ~2 minutes):
 *   1. Go to https://web3forms.com
 *   2. Enter the destination email (ryan@healthinthespirit.com OR annie@healthinthespirit.com)
 *   3. Confirm the email — Web3Forms sends an access key
 *   4. Replace the placeholder access key below in the page that uses this form
 *
 * Until a real access key is set, the form will return an error on submit
 * (the layout still renders correctly so you can preview the design).
 */

interface Field {
  name: string;
  label: string;
  type?: 'text' | 'email' | 'tel' | 'url';
  required?: boolean;
  placeholder?: string;
  fullWidth?: boolean;
}

interface Props {
  formId: string;             // unique on-page id (used for JS scoping)
  accessKey: string;          // Web3Forms access key
  subject: string;            // becomes email subject line
  fields: Field[];
  textareaName?: string;      // name of the long-message field
  textareaLabel?: string;
  textareaRequired?: boolean;
  submitLabel?: string;
  successMessage?: string;
}

const {
  formId,
  accessKey,
  subject,
  fields,
  textareaName = 'message',
  textareaLabel = 'Message',
  textareaRequired = true,
  submitLabel = 'Send',
  successMessage = "Thanks — your message is on its way. We'll respond as soon as we can.",
} = Astro.props;
---
<form
  id={formId}
  data-contact-form
  data-success-message={successMessage}
  action="https://api.web3forms.com/submit"
  method="POST"
  class="space-y-5"
>
  <input type="hidden" name="access_key" value={accessKey} />
  <input type="hidden" name="subject" value={subject} />
  <input type="hidden" name="from_name" value="Health in the Spirit website" />

  {/* Honeypot — bots fill this; humans don't see it. Web3Forms drops submissions where this is non-empty. */}
  <input type="checkbox" name="botcheck" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true" />

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    {fields.map((field) => (
      <div class={field.fullWidth ? 'sm:col-span-2' : ''}>
        <label for={`${formId}-${field.name}`} class="block text-xs uppercase tracking-[0.18em] text-gold-700 font-semibold mb-2">
          {field.label}{field.required && <span class="text-terracotta-500" aria-hidden="true">*</span>}
        </label>
        <input
          id={`${formId}-${field.name}`}
          type={field.type || 'text'}
          name={field.name}
          required={field.required}
          placeholder={field.placeholder}
          class="w-full px-4 py-3 rounded-md bg-cream-100 border border-cream-400 text-brown-700 placeholder:text-brown-400 focus-visible:outline-2 focus-visible:outline-gold-500 focus-visible:border-gold-400"
        />
      </div>
    ))}
  </div>

  <div>
    <label for={`${formId}-${textareaName}`} class="block text-xs uppercase tracking-[0.18em] text-gold-700 font-semibold mb-2">
      {textareaLabel}{textareaRequired && <span class="text-terracotta-500" aria-hidden="true">*</span>}
    </label>
    <textarea
      id={`${formId}-${textareaName}`}
      name={textareaName}
      required={textareaRequired}
      rows="6"
      class="w-full px-4 py-3 rounded-md bg-cream-100 border border-cream-400 text-brown-700 placeholder:text-brown-400 focus-visible:outline-2 focus-visible:outline-gold-500 focus-visible:border-gold-400"
    ></textarea>
  </div>

  <div class="flex flex-col sm:flex-row sm:items-center gap-4">
    <button
      type="submit"
      class="inline-flex items-center justify-center gap-2 bg-terracotta-500 hover:bg-terracotta-600 text-cream-100 font-semibold uppercase tracking-[0.12em] text-sm px-7 py-3.5 rounded-md transition-colors disabled:opacity-60 disabled:cursor-wait"
    >
      <span data-submit-label>{submitLabel}</span>
      <span data-submit-spinner class="hidden">…sending</span>
    </button>
    <p data-form-status class="text-sm text-brown-700 italic" aria-live="polite"></p>
  </div>
</form>

<script>
  // Progressive enhancement — without JS, the form still posts to Web3Forms (full page reload).
  // With JS, we POST via fetch and show inline success/error messages.
  document.querySelectorAll<HTMLFormElement>('[data-contact-form]').forEach((form) => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const status = form.querySelector<HTMLElement>('[data-form-status]');
      const button = form.querySelector<HTMLButtonElement>('button[type="submit"]');
      const label = form.querySelector<HTMLElement>('[data-submit-label]');
      const spinner = form.querySelector<HTMLElement>('[data-submit-spinner]');
      const successMsg = form.dataset.successMessage || 'Sent!';

      if (button) button.disabled = true;
      label?.classList.add('hidden');
      spinner?.classList.remove('hidden');
      if (status) { status.textContent = ''; status.className = 'text-sm text-brown-700 italic'; }

      try {
        const formData = new FormData(form);
        const res = await fetch(form.action, {
          method: 'POST',
          body: formData,
          headers: { Accept: 'application/json' },
        });
        const data = await res.json().catch(() => ({}));
        if (res.ok && (data.success === true || res.status === 200)) {
          form.reset();
          if (status) {
            status.textContent = successMsg;
            status.className = 'text-sm text-forest-700 font-semibold';
          }
        } else {
          if (status) {
            status.textContent = data.message || 'Could not send. Please try again or email directly.';
            status.className = 'text-sm text-terracotta-600 font-semibold';
          }
        }
      } catch (err) {
        if (status) {
          status.textContent = 'Network error. Please try again or email directly.';
          status.className = 'text-sm text-terracotta-600 font-semibold';
        }
      } finally {
        if (button) button.disabled = false;
        label?.classList.remove('hidden');
        spinner?.classList.add('hidden');
      }
    });
  });
</script>
