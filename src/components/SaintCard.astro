---
interface Props {
  name: string;
  href: string;
  role?: string;
  era?: string;
  summary?: string;
  imageSrc?: string;
  imageAlt?: string;
}

const { name, href, role, era, summary, imageSrc, imageAlt = '' } = Astro.props;
---
<a
  href={href}
  class="group flex flex-col rounded-lg overflow-hidden bg-cream-100 border border-gold-200 transition-all duration-200 hover:-translate-y-1 hover:shadow-md hover:border-gold-400"
>
  <div class="aspect-square bg-sage-100 flex items-center justify-center overflow-hidden">
    {imageSrc ? (
      <img src={imageSrc} alt={imageAlt} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
    ) : (
      <div class="w-3/4 h-3/4 rounded-full border-2 border-gold-400 flex items-center justify-center bg-cream-200">
        <span class="font-serif text-5xl text-gold-600 italic">{name[0]}</span>
      </div>
    )}
  </div>

  <div class="flex flex-col gap-2 p-6 text-center">
    {era && (
      <p class="text-xs uppercase tracking-[0.2em] text-gold-700 font-semibold">{era}</p>
    )}

    <h3 class="font-serif text-2xl leading-tight font-semibold text-forest-700 group-hover:text-terracotta-500 transition-colors">
      {name}
    </h3>

    {role && (
      <p class="text-sm italic font-serif text-brown-600">{role}</p>
    )}

    {summary && (
      <p class="text-base leading-relaxed text-brown-700 mt-2">{summary}</p>
    )}
  </div>
</a>
