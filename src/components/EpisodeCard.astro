---
// Episode shape — matches the `episodes` content collection schema in src/content.config.ts.
// Accepts releaseDate as a Date (from the collection) OR string (legacy / hand-passed objects).
interface Episode {
  number: number;
  title: string;
  description: string;
  releaseDate: Date | string;
  status: 'upcoming' | 'live';
  durationMinutes?: number;
  guestName?: string;
  buzzsproutEmbedId?: string;
  spotifyEmbedUrl?: string;
  youtubeEmbedUrl?: string;
  appleEpisodeUrl?: string;
}

interface Props {
  episode: Episode;
}

const { episode } = Astro.props;

const releaseDateObj = new Date(episode.releaseDate);
const releaseLabel = releaseDateObj.toLocaleString('en-US', {
  weekday: 'long', month: 'long', day: 'numeric',
  hour: 'numeric', minute: '2-digit',
  timeZone: 'America/New_York', timeZoneName: 'short',
});
const releaseIso = releaseDateObj.toISOString();

const isLive = episode.status === 'live';
const hasEmbed = Boolean(episode.buzzsproutEmbedId || episode.spotifyEmbedUrl || episode.youtubeEmbedUrl);
---
<article class="bg-cream-100 border border-cream-400 rounded-lg overflow-hidden flex flex-col">

  {/* Header strip */}
  <div class="px-6 sm:px-7 pt-6 pb-4 border-b border-cream-300">
    <div class="flex items-center justify-between gap-3">
      <p class="text-xs uppercase tracking-[0.18em] text-gold-700 font-semibold">
        Episode {episode.number}
      </p>
      <span class:list={[
        'text-[10px] uppercase tracking-[0.18em] font-semibold px-2 py-1 rounded',
        isLive ? 'bg-sage-200 text-forest-700' : 'bg-cream-300 text-brown-600',
      ]}>
        {isLive ? 'Live now' : 'Upcoming'}
      </span>
    </div>
    <h3 class="mt-3 font-serif text-xl sm:text-2xl text-forest-700 leading-tight">
      {episode.title}
    </h3>
    {episode.guestName && (
      <p class="mt-1 text-sm italic font-serif text-brown-600">with {episode.guestName}</p>
    )}
  </div>

  {/* Body */}
  <div class="px-6 sm:px-7 py-5 flex-1">
    <p class="text-base text-brown-700 leading-relaxed">{episode.description}</p>

    {hasEmbed ? (
      <div class="mt-5 space-y-3">
        {episode.buzzsproutEmbedId && (
          <iframe
            src={`https://www.buzzsprout.com/${episode.buzzsproutEmbedId}.html?artist=&container_id=buzzsprout-player-${episode.number}&player=small`}
            loading="lazy"
            width="100%"
            height="200"
            frameborder="0"
            scrolling="no"
            title={`${episode.title} — Buzzsprout player`}
            class="rounded-md"
          ></iframe>
        )}
        {episode.spotifyEmbedUrl && (
          <iframe
            src={episode.spotifyEmbedUrl}
            loading="lazy"
            width="100%"
            height="152"
            frameborder="0"
            allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
            allowfullscreen
            title={`${episode.title} — Spotify player`}
            class="rounded-md"
          ></iframe>
        )}
        {episode.youtubeEmbedUrl && (
          <iframe
            src={episode.youtubeEmbedUrl}
            loading="lazy"
            width="100%"
            height="200"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            title={`${episode.title} — YouTube`}
            class="rounded-md"
          ></iframe>
        )}
      </div>
    ) : (
      <p class="mt-5 text-xs uppercase tracking-[0.18em] text-terracotta-500 font-semibold">
        Drops <time datetime={releaseIso}>{releaseLabel}</time>
      </p>
    )}
  </div>

  {/* Footer links */}
  {(episode.appleEpisodeUrl || episode.spotifyEmbedUrl) && (
    <div class="px-6 sm:px-7 pb-5 pt-2 flex flex-wrap gap-2 text-xs uppercase tracking-[0.15em] font-semibold">
      {episode.appleEpisodeUrl && (
        <a href={episode.appleEpisodeUrl} target="_blank" rel="noopener noreferrer" class="text-terracotta-500 hover:text-terracotta-600">Apple Podcasts →</a>
      )}
    </div>
  )}
</article>
