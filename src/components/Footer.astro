---
import { site } from '../lib/site';

const siteCol = [
  { label: 'Home',       href: '/' },
  { label: 'About',      href: '/about' },
  { label: 'The Saints', href: '/saints' },
  { label: 'Episodes',   href: '/episodes' },
  { label: 'Subscribe',  href: '/subscribe' },
  { label: 'Resources',  href: '/resources' },
  { label: 'Blog',       href: '/blog' },
  { label: 'Contact',    href: '/contact' },
];
const moreCol = [
  { label: 'FAQ',              href: '/faq' },
  { label: 'Press Kit',        href: '/press' },
  { label: 'Privacy Policy',   href: '/privacy' },
  { label: 'Terms of Service', href: '/terms' },
];

// Social links — only the ones with real URLs become clickable.
// Until accounts go live they show as "coming soon" placeholders.
const socialDefs = [
  { key: 'applePodcasts', label: 'Apple Podcasts' },
  { key: 'spotify',       label: 'Spotify' },
  { key: 'youtube',       label: 'YouTube' },
  { key: 'instagram',     label: 'Instagram' },
] as const;

const year = new Date().getFullYear();
---
<footer class="bg-forest-700 text-cream-200 mt-16 sm:mt-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">

      <div>
        <p class="font-serif text-2xl text-cream-200 leading-tight">
          Health<br/>in the Spirit
        </p>
        <p class="mt-3 text-sm text-cream-300/80 italic max-w-xs">
          Care for your body like you're going to live forever — care for your soul like you're going to die tomorrow.
        </p>
      </div>

      <nav aria-label="Footer site links">
        <h2 class="text-xs font-semibold uppercase tracking-[0.18em] text-gold-500 mb-4">Site</h2>
        <ul class="space-y-2">
          {siteCol.map((item) => (
            <li><a href={item.href} class="text-sm text-cream-200 hover:text-gold-500 transition-colors">{item.label}</a></li>
          ))}
        </ul>
      </nav>

      <nav aria-label="Footer more links">
        <h2 class="text-xs font-semibold uppercase tracking-[0.18em] text-gold-500 mb-4">More</h2>
        <ul class="space-y-2">
          {moreCol.map((item) => (
            <li><a href={item.href} class="text-sm text-cream-200 hover:text-gold-500 transition-colors">{item.label}</a></li>
          ))}
        </ul>
      </nav>

      <div>
        <h2 class="text-xs font-semibold uppercase tracking-[0.18em] text-gold-500 mb-4">Connect</h2>
        <ul class="space-y-2 text-sm">
          <li>
            <a href={`mailto:${site.contactEmail}`} class="text-cream-200 hover:text-gold-500 transition-colors">
              {site.contactEmail}
            </a>
          </li>
          {socialDefs.map(({ key, label }) => {
            const url = site.socialUrls[key];
            return url
              ? <li><a href={url} target="_blank" rel="noopener noreferrer" class="text-cream-200 hover:text-gold-500 transition-colors">{label}</a></li>
              : <li class="text-cream-300/60">{label} <span class="italic text-xs">(coming soon)</span></li>;
          })}
        </ul>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-forest-600/60 text-xs text-cream-300/70 flex flex-col sm:flex-row justify-between gap-2">
      <p>&copy; {year} Health in the Spirit. All rights reserved.</p>
      <p class="italic">Sts. Cosmas & Damian · St. Hildegard of Bingen · St. Augustine of Hippo — pray for us.</p>
    </div>
  </div>
</footer>
