---
const navItems = [
  { label: 'About',       href: '/about' },
  { label: 'The Saints',  href: '/saints' },
  { label: 'Episodes',    href: '/episodes' },
  { label: 'Resources',   href: '/resources' },
  { label: 'Blog',        href: '/blog' },
];
const currentPath = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? currentPath === '/' : currentPath.startsWith(href);
---
<header class="bg-cream-200 border-b border-cream-400 sticky top-0 z-40">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 sm:h-24 items-center justify-between gap-4">
      <a href="/" class="flex items-center shrink-0" aria-label="Health in the Spirit home">
        <img
          src="/brand/main-logo.png"
          alt="Health in the Spirit"
          width="308"
          height="100"
          class="h-12 sm:h-16 w-auto"
        />
      </a>

      <nav class="hidden lg:flex items-center gap-7" aria-label="Primary">
        {navItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              'text-sm font-medium tracking-wide uppercase transition-colors',
              isActive(item.href)
                ? 'text-terracotta-500'
                : 'text-forest-700 hover:text-terracotta-500',
            ]}
            aria-current={isActive(item.href) ? 'page' : undefined}
          >
            {item.label}
          </a>
        ))}
      </nav>

      <a
        href="/subscribe"
        class="hidden sm:inline-flex items-center gap-2 bg-terracotta-500 hover:bg-terracotta-600 text-cream-100 font-semibold uppercase tracking-wider text-xs sm:text-sm px-4 sm:px-5 py-2.5 rounded-md transition-colors"
      >
        Listen Now
      </a>

      <button
        type="button"
        id="mobile-menu-toggle"
        class="lg:hidden inline-flex items-center justify-center w-10 h-10 rounded-md text-forest-700 hover:bg-cream-300"
        aria-controls="mobile-menu"
        aria-expanded="false"
        aria-label="Open primary menu"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
    </div>

    <div id="mobile-menu" class="lg:hidden hidden pb-4">
      <a
        href="/subscribe"
        class="block w-full text-center bg-terracotta-500 hover:bg-terracotta-600 text-cream-100 font-semibold uppercase tracking-wider text-sm px-5 py-3 rounded-md mb-3"
      >
        Listen Now
      </a>
      <nav class="flex flex-col gap-1" aria-label="Mobile primary">
        {navItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              'block px-3 py-2 rounded-md text-base font-medium uppercase tracking-wide',
              isActive(item.href)
                ? 'text-terracotta-500 bg-cream-300'
                : 'text-forest-700 hover:bg-cream-300',
            ]}
            aria-current={isActive(item.href) ? 'page' : undefined}
          >
            {item.label}
          </a>
        ))}
      </nav>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(open));
    toggle.setAttribute('aria-label', open ? 'Close primary menu' : 'Open primary menu');
  });
</script>
