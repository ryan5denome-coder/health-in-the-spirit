---
// Wraps long-form content (markdown bodies, page bodies) with consistent typography
// matching the brand: Cormorant Garamond headings, Inter body, dark brown text.
---
<div class="prose-hits">
  <slot />
</div>

<style is:global>
  .prose-hits {
    --text: var(--color-brown-700);
    --heading: var(--color-forest-700);
    --accent: var(--color-terracotta-500);
    --link: var(--color-terracotta-500);
    --quote: var(--color-gold-700);
    --rule: var(--color-cream-400);

    color: var(--text);
    font-family: var(--font-body);
    font-size: 1.125rem;
    line-height: 1.7;
    max-width: 70ch;
  }
  .prose-hits > * + * { margin-top: 1.25rem; }
  .prose-hits h2,
  .prose-hits h3,
  .prose-hits h4 {
    font-family: var(--font-display);
    color: var(--heading);
    line-height: 1.2;
    letter-spacing: -0.01em;
  }
  .prose-hits h2 { font-size: 2rem; margin-top: 3rem; font-weight: 600; }
  .prose-hits h3 { font-size: 1.5rem; margin-top: 2.25rem; font-weight: 500; }
  .prose-hits h4 { font-size: 1.25rem; margin-top: 1.75rem; font-weight: 500; }
  .prose-hits p { margin: 0 0 1.25rem; }
  .prose-hits a {
    color: var(--link);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    transition: color 0.15s ease;
  }
  .prose-hits a:hover { color: var(--color-terracotta-600); }
  .prose-hits strong { color: var(--heading); font-weight: 600; }
  .prose-hits em { font-style: italic; }
  .prose-hits ul,
  .prose-hits ol { padding-left: 1.5rem; margin: 1.25rem 0; }
  .prose-hits li { margin-bottom: 0.5rem; }
  .prose-hits blockquote {
    border-left: 3px solid var(--color-gold-500);
    padding: 0.25rem 1.25rem;
    margin: 2rem 0;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.375rem;
    line-height: 1.5;
    color: var(--quote);
  }
  .prose-hits hr {
    border: 0;
    border-top: 1px solid var(--rule);
    margin: 2.5rem 0;
  }
  .prose-hits img {
    border-radius: 0.5rem;
    margin: 2rem 0;
  }
  .prose-hits code {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.95em;
    background: var(--color-cream-300);
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
  }
</style>
