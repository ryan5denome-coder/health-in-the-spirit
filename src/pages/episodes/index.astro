---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionContainer from '../../components/SectionContainer.astro';
import Countdown from '../../components/Countdown.astro';
import Button from '../../components/Button.astro';
import EpisodeCard from '../../components/EpisodeCard.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { SITE_URL } from '../../lib/schema';

const launchIso = '2026-07-07T06:00:00-04:00';

const allEntries = (await getCollection('episodes', ({ data }) => !data.draft));
const allEpisodes = allEntries
  .map((e) => e.data)
  .sort((a, b) => {
    const ad = a.releaseDate.getTime();
    const bd = b.releaseDate.getTime();
    if (bd !== ad) return bd - ad;
    return b.number - a.number;
  });

const liveEpisodes = allEpisodes.filter((e) => e.status === 'live');
const upcomingEpisodes = allEpisodes.filter((e) => e.status === 'upcoming');

// Per-episode PodcastEpisode schema. When status flips to 'live' and an audio
// URL exists, we emit a fully-spec'd PodcastEpisode (with associatedMedia /
// contentUrl). Until then, an "upcoming" PodcastEpisode entry tells crawlers
// the episode exists and when it drops.
const episodeSchemas = allEpisodes.map((ep) => {
  const epUrl = `${SITE_URL}/episodes/#ep${ep.number}`;
  const base: Record<string, unknown> = {
    '@context': 'https://schema.org',
    '@type': 'PodcastEpisode',
    '@id': epUrl,
    name: ep.title,
    description: ep.description,
    episodeNumber: ep.number,
    datePublished: ep.releaseDate.toISOString(),
    inLanguage: 'en-US',
    url: epUrl,
    partOfSeries: { '@id': `${SITE_URL}#podcast` },
  };
  if (ep.guestName) base.actor = { '@type': 'Person', name: ep.guestName };
  if (ep.audioUrl) {
    base.associatedMedia = {
      '@type': 'MediaObject',
      contentUrl: ep.audioUrl,
      encodingFormat: 'audio/mpeg',
    };
  }
  if (ep.imageSrc) base.image = `${SITE_URL}${ep.imageSrc}`;
  return base;
});

// CollectionPage wrapping the episode list — helps Google understand this is
// the canonical episodes index.
const indexSchema: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  '@id': `${SITE_URL}/episodes/#page`,
  url: `${SITE_URL}/episodes`,
  name: 'Health in the Spirit — Episodes',
  description: 'All episodes of the Health in the Spirit Catholic health and wellness podcast.',
  isPartOf: { '@id': `${SITE_URL}#website` },
  about: { '@id': `${SITE_URL}#podcast` },
  hasPart: episodeSchemas.map((s) => ({ '@id': s['@id'] })),
};
---
<BaseLayout
  title="Episodes | Catholic Health Podcast | Health in the Spirit"
  description="Browse every episode of Health in the Spirit — the Catholic health and wellness podcast bridging holistic medicine, Catholic theology, and the healing saints. Three episodes drop on launch day, July 7, 2026."
  jsonLd={[indexSchema, ...episodeSchemas]}
  breadcrumbs={[{ name: 'Episodes', url: '/episodes' }]}
  keywords={['Catholic podcast episodes', 'Catholic health podcast', 'Holistic health podcast', 'Saints podcast']}
>

  <SectionContainer variant="cream" padding="compact">
    <div class="max-w-7xl mx-auto">
      <Breadcrumbs items={[{ name: 'Episodes', url: '/episodes' }]} />
    </div>
  </SectionContainer>

  <SectionContainer variant="cream" padding="large">
    <div class="max-w-3xl mx-auto text-center">
      <h1 class="font-serif text-4xl sm:text-5xl lg:text-6xl text-forest-700 leading-tight">
        Catholic Health Podcast Episodes
      </h1>
      <p class="mt-6 text-xl text-brown-700 italic font-serif">
        Three episodes drop on launch day — Tuesday, July 7, 2026. Weekly after that.
      </p>
    </div>
  </SectionContainer>

  {liveEpisodes.length === 0 && (
    <Countdown targetIso={launchIso} preLaunchHeadline="Episodes 1, 2 & 3 launch in" />
  )}

  {liveEpisodes.length > 0 && (
    <SectionContainer variant="cream" padding="default" id="latest">
      <div class="max-w-7xl mx-auto">
        <h2 class="font-serif text-3xl sm:text-4xl text-forest-700 mb-10 leading-tight">Latest episodes</h2>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 sm:gap-8">
          {liveEpisodes.map((ep) => <EpisodeCard episode={ep} />)}
        </div>
      </div>
    </SectionContainer>
  )}

  {upcomingEpisodes.length > 0 && (
    <SectionContainer variant="cream" padding="default" id="upcoming">
      <div class="max-w-7xl mx-auto">
        <div class="text-center max-w-2xl mx-auto mb-10">
          <h2 class="font-serif text-3xl sm:text-4xl text-forest-700 leading-tight">
            Three episodes, one launch day
          </h2>
          <p class="mt-4 text-lg text-brown-700">
            We are dropping the full mission set on day one — so you can dive in deep, or come back through the week.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 sm:gap-8">
          {upcomingEpisodes.map((ep) => <EpisodeCard episode={ep} />)}
        </div>
      </div>
    </SectionContainer>
  )}

  <SectionContainer variant="sage" padding="default">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="font-serif text-3xl sm:text-4xl text-forest-700 leading-tight">
        Subscribe to be ready when it drops
      </h2>
      <div class="mt-8 flex flex-wrap justify-center gap-3 sm:gap-4">
        <Button href="/subscribe" variant="primary" size="lg" arrow>Subscribe to be first</Button>
        <Button href="/saints" variant="secondary" size="lg">Meet the saints</Button>
      </div>
      <p class="mt-8 text-sm text-brown-500 italic max-w-xl mx-auto">
        Episode players above auto-activate the moment audio is published. The page renders Buzzsprout, Spotify, or YouTube embeds based on whichever fields are set per episode — drop-in, no code change required.
      </p>
    </div>
  </SectionContainer>

</BaseLayout>
