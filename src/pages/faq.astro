---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionContainer from '../components/SectionContainer.astro';

const faqs = [
  {
    q: 'When does the podcast launch?',
    a: 'Tuesday, July 7, 2026 at 6:00 AM Eastern Time. New episodes drop every Tuesday morning after that.',
  },
  {
    q: 'Where can I listen?',
    a: 'Apple Podcasts, Spotify, YouTube, Amazon Music, and any podcast app via our RSS feed. Subscribe links go live on the /subscribe page once each platform is set up.',
  },
  {
    q: 'Are Dr. Ryan and Annie taking guests on the show?',
    a: 'Yes. Email annie@healthinthespirit.com with a one-paragraph topic pitch and a link to a sample of your work. Annie handles all guest scheduling.',
  },
  {
    q: 'Can I see Dr. Ryan as a patient?',
    a: 'Yes. Visit thewellnessway.com/mason or use the Contact page to reach his clinic, The Wellness Way Mason in Mason, Ohio.',
  },
  {
    q: 'Is the podcast affiliated with The Wellness Way?',
    a: 'Dr. Ryan is the chiropractor of The Wellness Way Mason. Health in the Spirit is its own venture — Catholic in framing, broader in topic — and is not a corporate Wellness Way property.',
  },
  {
    q: 'How do you decide which saints to feature?',
    a: 'We started with Cosmas & Damian, Hildegard of Bingen, and Augustine of Hippo because they explicitly held body and soul together. As the show grows, we will profile more — including St. Luke, St. Raphael, Padre Pio, and St. Gianna Beretta Molla.',
  },
];

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---
<BaseLayout
  title="FAQ | Health in the Spirit"
  description="Frequently asked questions about the Health in the Spirit Catholic health and wellness podcast — launch date, hosts, guest applications, and more."
  jsonLd={faqJsonLd}
>

  <SectionContainer variant="cream" padding="large">
    <div class="max-w-3xl mx-auto text-center">
      <h1 class="font-serif text-4xl sm:text-5xl lg:text-6xl text-forest-700 leading-tight">
        Frequently asked questions
      </h1>
    </div>
  </SectionContainer>

  <SectionContainer variant="cream" padding="default">
    <div class="max-w-3xl mx-auto space-y-4">
      {faqs.map((f) => (
        <details class="group bg-cream-100 border border-cream-400 rounded-lg p-6 sm:p-7 [&_summary::-webkit-details-marker]:hidden">
          <summary class="cursor-pointer flex items-start justify-between gap-4 list-none">
            <h2 class="font-serif text-xl sm:text-2xl text-forest-700 leading-tight">{f.q}</h2>
            <span class="text-gold-600 text-2xl leading-none transition-transform group-open:rotate-45 mt-1" aria-hidden="true">+</span>
          </summary>
          <p class="mt-4 text-base text-brown-700 leading-relaxed">{f.a}</p>
        </details>
      ))}
    </div>
  </SectionContainer>

</BaseLayout>
