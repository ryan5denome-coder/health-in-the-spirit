---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionContainer from '../components/SectionContainer.astro';
import Button from '../components/Button.astro';
---
<BaseLayout
  title="Press & Media Kit | Health in the Spirit"
  description="Press and media kit for Health in the Spirit — bios, brand assets, show stats, and host headshots for journalists, bookers, and partners."
  noindex={false}
>

  <SectionContainer variant="cream" padding="large">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-xs uppercase tracking-[0.25em] text-gold-700 font-semibold mb-4">Press</p>
      <h1 class="font-serif text-4xl sm:text-5xl lg:text-6xl text-forest-700 leading-tight">
        Press &amp; Media Kit
      </h1>
      <p class="mt-6 text-xl text-brown-700 italic font-serif">
        Everything journalists, bookers, and partners need in one place.
      </p>
    </div>
  </SectionContainer>

  <SectionContainer variant="cream" padding="default" id="about-show">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-serif text-3xl text-forest-700">About the show</h2>
      <p class="mt-3 text-xs uppercase tracking-[0.18em] text-gold-700 font-semibold">One-sentence tagline</p>
      <p class="mt-2 text-lg text-brown-700">
        A Catholic health and wellness podcast where holistic medicine meets the wisdom of the healing saints.
      </p>

      <p class="mt-6 text-xs uppercase tracking-[0.18em] text-gold-700 font-semibold">50-word bio</p>
      <p class="mt-2 text-lg text-brown-700">
        Health in the Spirit is the Catholic health and wellness podcast hosted by Dr. Ryan and Annie DeNome. Through the lens of Sts. Cosmas & Damian, Hildegard, and Augustine, they bridge holistic medicine with Catholic theology — caring for the body God designed and the soul He redeemed.
      </p>

      <p class="mt-6 text-xs uppercase tracking-[0.18em] text-gold-700 font-semibold">Show stats <span class="text-brown-500 italic normal-case">(launching soon)</span></p>
      <ul class="mt-2 text-base text-brown-700 list-disc pl-5 space-y-1">
        <li>Launch date: <strong>Tuesday, July 7, 2026</strong></li>
        <li>Cadence: Weekly, every Tuesday</li>
        <li>Average episode length: 45–60 minutes</li>
        <li>Format: Solo teaching + guest interviews</li>
      </ul>
    </div>
  </SectionContainer>

  <SectionContainer variant="sage" padding="default" id="brand-assets">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-serif text-3xl text-forest-700">Brand assets</h2>
      <p class="mt-3 text-base text-brown-700">
        Logos in SVG (scalable to any size, transparent backgrounds). Right-click and save, or contact us for higher-res variants.
      </p>

      <div class="mt-8 grid grid-cols-1 sm:grid-cols-2 gap-4 sm:gap-6">
        <a href="/brand/main-logo.svg" download class="bg-cream-100 border border-cream-400 rounded-lg p-6 flex items-center gap-5 hover:border-gold-400 transition-colors">
          <img src="/brand/main-logo.svg" alt="" class="w-16 h-16 object-contain" />
          <div>
            <p class="font-serif text-lg text-forest-700">Main logo</p>
            <p class="text-xs uppercase tracking-[0.15em] text-terracotta-500 font-semibold mt-1">Download SVG →</p>
          </div>
        </a>
        <a href="/brand/emblem.svg" download class="bg-cream-100 border border-cream-400 rounded-lg p-6 flex items-center gap-5 hover:border-gold-400 transition-colors">
          <img src="/brand/emblem.svg" alt="" class="w-16 h-16 object-contain" />
          <div>
            <p class="font-serif text-lg text-forest-700">Emblem only</p>
            <p class="text-xs uppercase tracking-[0.15em] text-terracotta-500 font-semibold mt-1">Download SVG →</p>
          </div>
        </a>
        <a href="/brand/stacked.svg" download class="bg-cream-100 border border-cream-400 rounded-lg p-6 flex items-center gap-5 hover:border-gold-400 transition-colors">
          <img src="/brand/stacked.svg" alt="" class="w-16 h-16 object-contain" />
          <div>
            <p class="font-serif text-lg text-forest-700">Stacked variant</p>
            <p class="text-xs uppercase tracking-[0.15em] text-terracotta-500 font-semibold mt-1">Download SVG →</p>
          </div>
        </a>
        <a href="/brand/wordmark.svg" download class="bg-cream-100 border border-cream-400 rounded-lg p-6 flex items-center gap-5 hover:border-gold-400 transition-colors">
          <img src="/brand/wordmark.svg" alt="" class="w-16 h-16 object-contain" />
          <div>
            <p class="font-serif text-lg text-forest-700">Wordmark</p>
            <p class="text-xs uppercase tracking-[0.15em] text-terracotta-500 font-semibold mt-1">Download SVG →</p>
          </div>
        </a>
      </div>
    </div>
  </SectionContainer>

  <SectionContainer variant="cream" padding="default" id="contact">
    <div class="max-w-2xl mx-auto text-center">
      <h2 class="font-serif text-3xl text-forest-700">Press inquiries</h2>
      <p class="mt-4 text-lg text-brown-700">
        For interview requests, partnership opportunities, and press questions:
      </p>
      <p class="mt-3">
        <a href="mailto:ryan@healthinthespirit.com" class="text-terracotta-500 hover:text-terracotta-600 underline underline-offset-2 font-semibold text-lg">
          ryan@healthinthespirit.com
        </a>
      </p>
      <div class="mt-8">
        <Button href="/contact" variant="secondary" size="md">All contact options →</Button>
      </div>
    </div>
  </SectionContainer>

</BaseLayout>
