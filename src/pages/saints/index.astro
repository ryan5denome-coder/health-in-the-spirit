---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionContainer from '../../components/SectionContainer.astro';
import SaintCard from '../../components/SaintCard.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

const allSaints = (await getCollection('saints', ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order);

const page = await getEntry('pages', 'saints-index');
const heroEyebrow = page?.data.heroEyebrow || 'The Saints';
const heroTitle   = page?.data.heroTitle   || 'The Healing Saints Who Guide Us';
const heroSubtitle = page?.data.heroSubtitle ||
  'Three witnesses across eighteen centuries. One unbroken Tradition that has always held the body and soul together.';
const moreSaintsNote = page?.data.moreSaintsNote ||
  'As the podcast grows, so will this collection — Saint Luke the Beloved Physician, Saint Raphael the Archangel, Saint Padre Pio, Saint Charbel Makhlouf, Saint Gianna Beretta Molla, and more. Each one a different facet of the same truth.';
---
<BaseLayout
  title="The Healing Saints Who Guide Us | Health in the Spirit"
  description="Meet the healing saints of the Catholic tradition — Augustine, Cosmas & Damian, Hildegard — who guide Health in the Spirit's approach to body and soul."
  breadcrumbs={[{ name: 'The Saints', url: '/saints' }]}
  keywords={['healing saints Catholic', 'Catholic patron saints', 'saints podcast', 'Cosmas and Damian', 'Hildegard of Bingen', 'Augustine of Hippo']}
>

  <SectionContainer variant="cream" padding="compact">
    <div class="max-w-3xl mx-auto">
      <Breadcrumbs items={[{ name: 'The Saints', url: '/saints' }]} />
    </div>
  </SectionContainer>

  <SectionContainer variant="cream" padding="large">
    <div class="max-w-3xl mx-auto text-center">
      <h1 class="font-serif text-4xl sm:text-5xl lg:text-6xl text-forest-700 leading-tight">
        {heroTitle}
      </h1>
      <p class="mt-6 text-xl text-brown-700 italic font-serif">
        {heroSubtitle}
      </p>
    </div>
  </SectionContainer>

  <SectionContainer variant="sage" padding="default" id="patrons">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 sm:gap-8">
      {allSaints.map((s) => (
        <SaintCard
          name={s.data.name}
          href={`/saints/${s.data.slug}`}
          role={s.data.role}
          era={s.data.era}
          summary={s.data.summary}
          imageSrc={s.data.iconImage}
          imageAlt={s.data.iconAlt}
        />
      ))}
    </div>
  </SectionContainer>

  <SectionContainer variant="cream" padding="default">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="font-serif text-3xl sm:text-4xl text-forest-700 leading-tight">More saints coming soon</h2>
      <p class="mt-4 text-lg text-brown-700">
        {moreSaintsNote}
      </p>
    </div>
  </SectionContainer>

</BaseLayout>
