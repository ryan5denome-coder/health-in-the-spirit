---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionContainer from '../components/SectionContainer.astro';
import Button from '../components/Button.astro';
---
<BaseLayout
  title="Catholic Health & Wellness Resources | Health in the Spirit"
  description="Catholic health resources — books, supplements, and trusted tools recommended by Dr. Ryan and Annie DeNome for body, soul, and family wellness."
>

  <SectionContainer variant="cream" padding="large">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-xs uppercase tracking-[0.25em] text-gold-700 font-semibold mb-4">Resources</p>
      <h1 class="font-serif text-4xl sm:text-5xl lg:text-6xl text-forest-700 leading-tight">
        Catholic Health Resources &amp; Recommendations
      </h1>
      <p class="mt-6 text-xl text-brown-700 italic font-serif">
        Books, supplements, and tools we trust — coming soon, with the same standard we hold for ourselves: nothing here we wouldn't put on our own shelf.
      </p>
    </div>
  </SectionContainer>

  <SectionContainer variant="sage" padding="default">
    <div class="max-w-4xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-cream-100 border border-cream-400 rounded-lg p-7">
          <p class="text-xs uppercase tracking-[0.18em] text-gold-700 font-semibold mb-2">Coming soon</p>
          <h3 class="font-serif text-2xl text-forest-700 leading-tight">Books</h3>
          <p class="mt-3 text-base text-brown-700">From Hildegard's <em>Physica</em> to modern Catholic theology of the body — the texts that have shaped how we think and practice.</p>
        </div>
        <div class="bg-cream-100 border border-cream-400 rounded-lg p-7">
          <p class="text-xs uppercase tracking-[0.18em] text-gold-700 font-semibold mb-2">Coming soon</p>
          <h3 class="font-serif text-2xl text-forest-700 leading-tight">Supplements</h3>
          <p class="mt-3 text-base text-brown-700">Specific products we use ourselves and recommend to patients — with honest reasoning for each one, not affiliate noise.</p>
        </div>
        <div class="bg-cream-100 border border-cream-400 rounded-lg p-7">
          <p class="text-xs uppercase tracking-[0.18em] text-gold-700 font-semibold mb-2">Coming soon</p>
          <h3 class="font-serif text-2xl text-forest-700 leading-tight">Tools</h3>
          <p class="mt-3 text-base text-brown-700">Apps, devices, and practical kits that have actually earned their place in our home and our practice.</p>
        </div>
      </div>

      <p class="mt-12 text-center text-sm text-brown-500 italic">
        Resources will be added gradually after launch — when each recommendation has been used, tested, and vetted personally.
      </p>
    </div>
  </SectionContainer>

  <SectionContainer variant="cream" padding="default">
    <div class="max-w-2xl mx-auto text-center">
      <Button href="/" variant="secondary" size="md">← Back to homepage</Button>
    </div>
  </SectionContainer>

</BaseLayout>
